APP_NAME="Portal Fornecedor On Demand"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.portalfornecedor.local

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=portal_ondemo
DB_USERNAME=portal
DB_PASSWORD=portal
DB_SSLMODE=prefer

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=portal-anexos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/portal-anexos

MAIL_MAILER=log

# Homolog Supabase: copie de ../env/laravel.homolog.supabase.example

JWT_SECRET=
JWT_TTL=3600
