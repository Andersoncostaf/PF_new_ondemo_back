APP_NAME="Portal Fornecedor On Demand"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.portalfornecedor.local

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=portal_ondemo
DB_USERNAME=portal
DB_PASSWORD=portal
DB_SSLMODE=prefer

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=portal-anexos
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_URL=http://localhost:9000/portal-anexos

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=noreply@portalfornecedor.local
MAIL_FROM_NAME="Portal Fornecedor On Demand"
MAIL_REPLY_TO=suporte@portalfornecedor.local
IDENTIDADE_WELCOME_MAIL_ENABLED=true
FRONTEND_TENANT_URL_TEMPLATE=http://portalfornecedor.{slug}.local:4200

# Homolog Supabase: copie de ../env/laravel.homolog.supabase.example

JWT_SECRET=
JWT_TTL=3600

# Sugestões de fornecedores (VendorList)
# n8n opcional; se desligado, usa LLM (se houver chave) e depois busca web pública.
CONTRATACAO_SUGESTAO_N8N_ENABLED=false
CONTRATACAO_SUGESTAO_N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
CONTRATACAO_SUGESTAO_N8N_TIMEOUT_SECONDS=15
CONTRATACAO_SUGESTAO_CACHE_TTL_HOURS=24
# OPENAI_API_KEY=sk-...
# CONTRATACAO_SUGESTAO_LLM_API_KEY=
# CONTRATACAO_SUGESTAO_LLM_BASE_URL=https://api.openai.com/v1
# CONTRATACAO_SUGESTAO_LLM_MODEL=gpt-4o-mini
CONTRATACAO_SUGESTAO_WEB_SEARCH_ENABLED=true
CONTRATACAO_SUGESTAO_WEB_SEARCH_TIMEOUT_SECONDS=20
